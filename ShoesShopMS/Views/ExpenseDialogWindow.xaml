<Window x:Class="ShoesShopMS.Views.ExpenseDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Expense"
        Height="300"
        Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    
    <Grid Margin="20">
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Expense Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Category" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="CategoryTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>

            <TextBlock Text="Amount" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="AmountTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>

            <TextBlock Text="Date" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <DatePicker x:Name="DatePicker" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>

            <TextBlock Text="Description" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Height="60" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,20" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Height="40" Width="100" Background="#4CAF50" Foreground="White" FontSize="12" Cursor="Hand" Margin="0,0,10,0" Click="SaveButton_Click"/>
                <Button Content="Cancel" Height="40" Width="100" Background="#F44336" Foreground="White" FontSize="12" Cursor="Hand" Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
<Page x:Class="ShoesShopMS.Views.Pages.PurchasePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Purchase"
      Background="#F5F5F5">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Purchase Management" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,20"/>
                
                <Button Content="➕ New Purchase" Height="40" Width="150" Background="#4CAF50" Foreground="White" FontSize="13" Cursor="Hand" Margin="0,0,0,20" Click="NewPurchase_Click"/>
                
                <Border Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E0E0">
                    <DataGrid x:Name="PurchaseDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNumber}" Width="120"/>
                            <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="150"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding PurchaseDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat=Rs. {0:F2}}" Width="120"/>
                            <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat=Rs. {0:F2}}" Width="120"/>
                            <DataGridTextColumn Header="Balance" Binding="{Binding RemainingBalance, StringFormat=Rs. {0:F2}}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
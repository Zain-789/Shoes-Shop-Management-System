<Page x:Class="ShoesShopMS.Views.Pages.ExpensesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Expenses"
      Background="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Expense Management" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,20"/>
                <Button Content="➕ Add Expense" Height="40" Width="150" Background="#E91E63" Foreground="White" Cursor="Hand" Margin="0,0,0,20" Click="AddExpense_Click"/>
                <Border Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E0E0">
                    <DataGrid x:Name="ExpensesDataGrid" AutoGenerateColumns="False" Background="White" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=Rs. {0:F2}}" Width="120"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding ExpenseDate, StringFormat=dd/MM/yyyy}" Width="120"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="300"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
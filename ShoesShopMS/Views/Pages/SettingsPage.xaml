<Page x:Class="ShoesShopMS.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings"
      Background="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,40" TextAlignment="Center"/>
                
                <Border Background="White" CornerRadius="8" Padding="40" BorderThickness="1" BorderBrush="#E0E0E0" Width="500">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Change Password" FontSize="14" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Current Password" FontSize="11" Margin="0,0,0,5" FontWeight="Medium"/>
                        <PasswordBox x:Name="CurrentPasswordBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="New Password" FontSize="11" Margin="0,0,0,5" FontWeight="Medium"/>
                        <PasswordBox x:Name="NewPasswordBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Confirm Password" FontSize="11" Margin="0,0,0,5" FontWeight="Medium"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,20"/>
                        
                        <TextBlock x:Name="MessageLabel" Text="" Foreground="#4CAF50" FontSize="11" Margin="0,0,0,20"/>
                        
                        <Button Content="Save Changes" Height="40" Background="#2196F3" Foreground="White" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="SaveChanges_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
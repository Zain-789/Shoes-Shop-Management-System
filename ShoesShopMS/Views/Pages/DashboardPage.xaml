<Page x:Class="ShoesShopMS.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard"
      Background="#F5F5F5">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel Orientation="Vertical">
                <!-- Title -->
                <TextBlock Text="Dashboard" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="#212121"
                           Margin="0,0,0,20"/>

                <!-- Stats Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Today's Sales -->
                    <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,10,15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Today's Sales" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TodaysSalesLabel" Text="Rs. 0" FontSize="24" FontWeight="Bold" Foreground="#2196F3"/>
                        </StackPanel>
                    </Border>

                    <!-- Today's Profit -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="0,0,10,15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Today's Profit" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TodaysProfitLabel" Text="Rs. 0" FontSize="24" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Stock -->
                    <Border Grid.Column="2" Background="White" CornerRadius="8" Margin="0,0,10,15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Total Stock" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TotalStockLabel" Text="0" FontSize="24" FontWeight="Bold" Foreground="#FF9800"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Customers -->
                    <Border Grid.Column="3" Background="White" CornerRadius="8" Margin="0,0,0,15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Total Customers" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TotalCustomersLabel" Text="0" FontSize="24" FontWeight="Bold" Foreground="#00BCD4"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Second Row Stats -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Pending Payments -->
                    <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,10,15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Pending Payments" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="PendingPaymentsLabel" Text="Rs. 0" FontSize="24" FontWeight="Bold" Foreground="#F44336"/>
                        </StackPanel>
                    </Border>

                    <!-- Low Stock Items -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="0,0,10,15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Low Stock Items" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="LowStockLabel" Text="0" FontSize="24" FontWeight="Bold" Foreground="#FF5722"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Products -->
                    <Border Grid.Column="2" Background="White" CornerRadius="8" Margin="0,0,10,15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Total Products" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TotalProductsLabel" Text="0" FontSize="24" FontWeight="Bold" Foreground="#9C27B0"/>
                        </StackPanel>
                    </Border>

                    <!-- Today's Expenses -->
                    <Border Grid.Column="3" Background="White" CornerRadius="8" Margin="0,0,0,15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Today's Expenses" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="ExpensesLabel" Text="Rs. 0" FontSize="24" FontWeight="Bold" Foreground="#E91E63"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Quick Actions -->
                <TextBlock Text="Quick Actions" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#212121"
                           Margin="0,20,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="➕ New Sale" Height="40" Width="150" Background="#2196F3" Foreground="White" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="➕ New Purchase" Height="40" Width="150" Background="#4CAF50" Foreground="White" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="➕ Add Customer" Height="40" Width="150" Background="#FF9800" Foreground="White" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="➕ Add Product" Height="40" Width="150" Background="#9C27B0" Foreground="White" Cursor="Hand"/>
                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>

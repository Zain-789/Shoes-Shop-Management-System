<Page x:Class="ShoesShopMS.Views.Pages.SalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Sales"
      Background="#F5F5F5">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Sales Management" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,20"/>
                
                <Button Content="➕ New Sale" Height="40" Width="150" Background="#2196F3" Foreground="White" FontSize="13" Cursor="Hand" Margin="0,0,0,20" Click="NewSale_Click"/>
                
                <Border Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E0E0">
                    <DataGrid x:Name="SalesDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Bill #" Binding="{Binding BillNumber}" Width="120"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat=Rs. {0:F2}}" Width="120"/>
                            <DataGridTextColumn Header="Profit" Binding="{Binding Profit, StringFormat=Rs. {0:F2}}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTemplateColumn Header="Action" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="👁️ View" Height="28" Width="80" Background="#2196F3" Foreground="White" FontSize="10" Cursor="Hand" Click="ViewSale_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
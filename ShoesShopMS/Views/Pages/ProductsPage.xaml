<Page x:Class="ShoesShopMS.Views.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Products Management"
      Background="#F5F5F5">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel Orientation="Vertical">
                <!-- Title -->
                <TextBlock Text="Product Management" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,20"/>

                <!-- Search and Add Section -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="SearchBox" Placeholder="Search by Article Number or Brand..." Height="40" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Grid.Column="0" Margin="0,0,10,0"/>
                    <Button Content="➕ Add Product" Height="40" Background="#4CAF50" Foreground="White" FontSize="12" Cursor="Hand" Grid.Column="1" Click="AddProduct_Click"/>
                </Grid>

                <!-- Products DataGrid -->
                <Border Background="White" CornerRadius="8" Padding="0" BorderThickness="1" BorderBrush="#E0E0E0">
                    <DataGrid x:Name="ProductsDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" Background="White" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Article" Binding="{Binding ArticleNumber}" Width="100"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding ProductType}" Width="100"/>
                            <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="100"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="80"/>
                            <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="80"/>
                            <DataGridTextColumn Header="Purchase Price" Binding="{Binding PurchasePrice, StringFormat=Rs. {0:F2}}" Width="120"/>
                            <DataGridTextColumn Header="Sale Price" Binding="{Binding SalePrice, StringFormat=Rs. {0:F2}}" Width="120"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding CurrentStock}" Width="80"/>
                            <DataGridTemplateColumn Header="Actions" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <Button Content="✏️ Edit" Height="28" Width="60" Background="#2196F3" Foreground="White" FontSize="10" Cursor="Hand" Margin="0,0,5,0" Click="EditProduct_Click"/>
                                            <Button Content="🗑️ Delete" Height="28" Width="60" Background="#F44336" Foreground="White" FontSize="10" Cursor="Hand" Click="DeleteProduct_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
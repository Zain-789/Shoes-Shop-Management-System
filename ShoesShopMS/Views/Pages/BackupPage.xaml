<Page x:Class="ShoesShopMS.Views.Pages.BackupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Backup"
      Background="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Backup & Restore" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,40" TextAlignment="Center"/>
                
                <Border Background="White" CornerRadius="8" Padding="40" BorderThickness="1" BorderBrush="#E0E0E0" Width="400">
                    <StackPanel Orientation="Vertical">
                        <Button Content="💾 Create Backup" Height="50" Background="#4CAF50" Foreground="White" FontSize="14" FontWeight="Bold" Cursor="Hand" Margin="0,0,0,15" Click="CreateBackup_Click"/>
                        <Button Content="📂 Restore Backup" Height="50" Background="#2196F3" Foreground="White" FontSize="14" FontWeight="Bold" Cursor="Hand" Click="RestoreBackup_Click"/>
                        <TextBlock x:Name="StatusLabel" Text="" Foreground="#4CAF50" FontSize="12" Margin="0,20,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
<Page x:Class="ShoesShopMS.Views.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reports"
      Background="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Reports" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,20"/>
                
                <!-- Date Range Selection -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker x:Name="FromDatePicker" Grid.Column="1" Height="35" Margin="0,0,20,0"/>
                    <TextBlock Text="To:" VerticalAlignment="Center" Grid.Column="2" Margin="0,0,10,0"/>
                    <DatePicker x:Name="ToDatePicker" Grid.Column="3" Height="35" Margin="0,0,10,0"/>
                    <Button Content="Generate Report" Height="35" Width="150" Background="#2196F3" Foreground="White" Grid.Column="4" Click="GenerateReport_Click"/>
                </Grid>

                <!-- Report Stats -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Background="White" CornerRadius="8" Margin="0,0,10,15" Padding="20" BorderThickness="1" BorderBrush="#E0E0E0">
                        <StackPanel>
                            <TextBlock Text="Total Sales" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TotalSalesLabel" Text="Rs. 0" FontSize="24" FontWeight="Bold" Foreground="#2196F3"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="White" CornerRadius="8" Margin="0,0,10,15" Padding="20" Grid.Column="1" BorderThickness="1" BorderBrush="#E0E0E0">
                        <StackPanel>
                            <TextBlock Text="Total Profit" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TotalProfitLabel" Text="Rs. 0" FontSize="24" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="White" CornerRadius="8" Margin="0,0,0,15" Padding="20" Grid.Column="2" BorderThickness="1" BorderBrush="#E0E0E0">
                        <StackPanel>
                            <TextBlock Text="Total Expenses" Foreground="#757575" FontSize="12" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TotalExpensesLabel" Text="Rs. 0" FontSize="24" FontWeight="Bold" Foreground="#F44336"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
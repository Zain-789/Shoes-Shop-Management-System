<Page x:Class="ShoesShopMS.Views.Pages.StockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Stock Management"
      Background="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Stock Management" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,20"/>
                <Border Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E0E0">
                    <DataGrid x:Name="StockDataGrid" AutoGenerateColumns="False" Background="White" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Article" Binding="{Binding ArticleNumber}" Width="100"/>
                            <DataGridTextColumn Header="Current Stock" Binding="{Binding CurrentStock}" Width="120"/>
                            <DataGridTextColumn Header="Minimum Stock" Binding="{Binding MinimumStock}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
<Page x:Class="ShoesShopMS.Views.Pages.CustomersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Customers"
      Background="#F5F5F5">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Customer Management" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,20"/>
                
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="SearchBox" Placeholder="Search by Name or Phone..." Height="40" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Grid.Column="0" Margin="0,0,10,0"/>
                    <Button Content="➕ Add Customer" Height="40" Background="#2196F3" Foreground="White" FontSize="12" Cursor="Hand" Grid.Column="1" Click="AddCustomer_Click"/>
                </Grid>
                
                <Border Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E0E0">
                    <DataGrid x:Name="CustomersDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding CustomerName}" Width="150"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="200"/>
                            <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat=Rs. {0:F2}}" Width="120"/>
                            <DataGridTemplateColumn Header="Action" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <Button Content="✏️ Edit" Height="28" Width="50" Background="#2196F3" Foreground="White" FontSize="10" Cursor="Hand" Margin="0,0,5,0" Click="EditCustomer_Click"/>
                                            <Button Content="🗑️" Height="28" Width="40" Background="#F44336" Foreground="White" FontSize="10" Cursor="Hand" Click="DeleteCustomer_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
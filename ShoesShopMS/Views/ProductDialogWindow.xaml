<Window x:Class="ShoesShopMS.Views.ProductDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Details"
        Height="600"
        Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        Loaded="Window_Loaded">
    
    <Grid Margin="20">
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Product Information" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Article Number" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="ArticleNumberTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>

            <TextBlock Text="Brand" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="BrandTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>

            <TextBlock Text="Color" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="ColorTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>

            <TextBlock Text="Size" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="SizeTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>

            <TextBlock Text="Material" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="MaterialTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>

            <TextBlock Text="Purchase Price" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="PurchasePriceTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>

            <TextBlock Text="Sale Price" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="SalePriceTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>

            <TextBlock Text="Discount (%)" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="DiscountTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15" Text="0"/>

            <TextBlock Text="Minimum Stock" FontSize="12" FontWeight="Medium" Margin="0,0,0,5"/>
            <TextBox x:Name="MinimumStockTextBox" Height="35" Padding="10" FontSize="12" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,25" Text="5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveButton" Content="Save" Height="40" Width="100" Background="#4CAF50" Foreground="White" FontSize="12" Cursor="Hand" Margin="0,0,10,0" Click="SaveButton_Click"/>
                <Button x:Name="CancelButton" Content="Cancel" Height="40" Width="100" Background="#F44336" Foreground="White" FontSize="12" Cursor="Hand" Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>